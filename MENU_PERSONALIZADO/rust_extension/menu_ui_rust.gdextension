[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
windows.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
windows.debug.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
windows.release.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
windows.editor.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
windows.editor.debug.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
windows.editor.release.x86_64 = "res://rust_extension/bin/menu_ui_rust.dll"
