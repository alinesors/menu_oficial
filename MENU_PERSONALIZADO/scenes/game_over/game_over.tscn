[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/game_over/game_over.gd" id="1_script"]
[ext_resource type="FontFile" path="res://fonts/Retro Gaming.ttf" id="2_retro_font"]
[ext_resource type="Texture2D" path="res://scenes/game_over/7.png" id="3_bg"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.06, 0.05, 0.06, 0.68)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.85, 0.73, 0.48, 0.9)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_button_primary"]
bg_color = Color(0.9, 0.5, 0.07, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.68, 0.31, 0.04, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_button_secondary"]
bg_color = Color(0.2, 0.13, 0.08, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.38, 0.24, 0.12, 1)

[node name="GameOverScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="TextureRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("3_bg")
expand_mode = 1
stretch_mode = 5

[node name="CenterBackdrop" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 4
anchor_left = 0.0
anchor_top = 0.5
anchor_right = 0.0
anchor_bottom = 0.5
offset_left = 20.0
offset_top = -98.0
offset_right = 456.0
offset_bottom = 98.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="CenterVBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 4
anchor_left = 0.0
anchor_top = 0.5
anchor_right = 0.0
anchor_bottom = 0.5
offset_left = 38.0
offset_top = -80.0
offset_right = 438.0
offset_bottom = 80.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="CenterVBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_retro_font")
theme_override_colors/font_color = Color(0.95, 0.98, 1, 1)
theme_override_colors/font_outline_color = Color(0.03, 0.07, 0.12, 1)
theme_override_constants/outline_size = 5
text = "GAME OVER"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="CenterVBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_retro_font")
theme_override_colors/font_color = Color(0.95, 0.98, 1, 1)
theme_override_colors/font_outline_color = Color(0.03, 0.07, 0.12, 1)
theme_override_constants/outline_size = 4
text = "Voce foi derrotado."
horizontal_alignment = 1

[node name="Buttons" type="HBoxContainer" parent="CenterVBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="RetryButton" type="Button" parent="CenterVBox/Buttons"]
custom_minimum_size = Vector2(176, 36)
layout_mode = 2
size_flags_horizontal = 3
theme_override_fonts/font = ExtResource("2_retro_font")
theme_override_colors/font_color = Color(0.16, 0.08, 0.04, 1)
theme_override_colors/font_focus_color = Color(0.16, 0.08, 0.04, 1)
theme_override_colors/font_hover_color = Color(0.16, 0.08, 0.04, 1)
theme_override_colors/font_pressed_color = Color(0.16, 0.08, 0.04, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_button_primary")
text = "Tentar Novamente"

[node name="MenuButton" type="Button" parent="CenterVBox/Buttons"]
custom_minimum_size = Vector2(176, 36)
layout_mode = 2
size_flags_horizontal = 3
theme_override_fonts/font = ExtResource("2_retro_font")
theme_override_colors/font_color = Color(0.95, 0.98, 1, 1)
theme_override_colors/font_focus_color = Color(0.95, 0.98, 1, 1)
theme_override_colors/font_hover_color = Color(0.95, 0.98, 1, 1)
theme_override_colors/font_pressed_color = Color(0.95, 0.98, 1, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_button_secondary")
text = "Menu Principal"

[connection signal="pressed" from="CenterVBox/Buttons/RetryButton" to="." method="_on_retry_button_pressed"]
[connection signal="pressed" from="CenterVBox/Buttons/MenuButton" to="." method="_on_menu_button_pressed"]
