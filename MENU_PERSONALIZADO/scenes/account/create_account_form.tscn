[sub_resource type="GDScript" id="GDScript_jigcp"]
script/source = "extends Control

@export var character_texture: Texture2D
@export_file(\"*.png\", \"*.jpg\", \"*.jpeg\", \"*.webp\") var character_texture_path: String = \"res://assets/menu_custom/personagem.png\"

@onready var _username: LineEdit = get_node_or_null(\"MainPanel/Margin/LayoutRow/LeftCard/LeftMargin/FormVBox/UsernameInput\")
@onready var _password: LineEdit = get_node_or_null(\"MainPanel/Margin/LayoutRow/LeftCard/LeftMargin/FormVBox/PasswordInput\")
@onready var _confirm_password: LineEdit = get_node_or_null(\"MainPanel/Margin/LayoutRow/LeftCard/LeftMargin/FormVBox/ConfirmPasswordInput\")
@onready var _feedback: Label = get_node_or_null(\"MainPanel/Margin/LayoutRow/LeftCard/LeftMargin/FormVBox/FeedbackLabel\")
@onready var _character_sprite: Sprite2D = get_node_or_null(\"MainPanel/Margin/LayoutRow/Pirate\")

func _has_required_nodes() -> bool:
	return _username != null and _password != null and _confirm_password != null and _feedback != null

func _ready() -> void:
	if not _has_required_nodes():
		push_warning(\"CreateAccountForm: required nodes not found.\")
		return
	if _character_sprite != null:
		if character_texture != null:
			_character_sprite.texture = character_texture
		elif not character_texture_path.is_empty() and ResourceLoader.exists(character_texture_path):
			var loaded := load(character_texture_path)
			if loaded is Texture2D:
				_character_sprite.texture = loaded
	_feedback.text = \"\"

func _on_create_account_button_pressed() -> void:
	if not _has_required_nodes():
		return

	var username := _username.text.strip_edges()
	var password := _password.text
	var confirm_password := _confirm_password.text

	if username.is_empty():
		_feedback.text = \"Informe um nome de usuario.\"
		return
	if password.length() < 6:
		_feedback.text = \"A senha precisa ter pelo menos 6 caracteres.\"
		return
	if password != confirm_password:
		_feedback.text = \"As senhas nao coincidem.\"
		return

	_feedback.text = \"Conta criada com sucesso (simulada)!\"
	_username.clear()
	_password.clear()
	_confirm_password.clear()

func _on_clear_button_pressed() -> void:
	if not _has_required_nodes():
		return

	_username.clear()
	_password.clear()
	_confirm_password.clear()
	_feedback.text = \"\"
"

